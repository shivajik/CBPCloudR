{
  "framework": null,
  "installCommand": "npx --yes pnpm@10 install --no-frozen-lockfile",
  "buildCommand": "npx --yes pnpm@10 --filter @workspace/cbp-cloud run build && mv artifacts/cbp-cloud/dist/public public",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
